{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Bash(npm run *)",
      "Bash(npm test)",
      "Bash(npm install*)",
      "Bash(node harness/*)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(export PATH=\"/opt/homebrew/bin:$PATH\" && npm *)",
      "Bash(export PATH=\"/opt/homebrew/bin:$PATH\" && node *)",
      "Bash(export PATH=\"/opt/homebrew/bin:$PATH\" && for *)",
      "Bash(export PATH=\"/opt/homebrew/bin:$PATH\" && gh *)",
      "Bash(echo *)",
      "Bash(tail *)",
      "Bash(jq *)",
      "Bash(ls *)",
      "Bash(cat *)"
    ],
    "deny": [
      "Bash(rm -rf*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)"
    ]
  }
}
